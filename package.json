{
  "name": "aegis",
  "private": true,
  "version": "0.1.0",
  "description": "Aegis — Gerenciador de senhas & autenticação 2FA (PWA + extensão Chrome)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @aegis/pwa",
    "dev:pwa": "npm run dev --workspace @aegis/pwa",
    "build": "npm run build --workspace @aegis/pwa && npm run build --workspace @aegis/extension",
    "build:pwa": "npm run build --workspace @aegis/pwa",
    "build:extension": "npm run build --workspace @aegis/extension",
    "typecheck": "tsc -b apps/pwa apps/extension"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
