# Google OAuth Client ID (tipo "Web application") para o pull do cofre via Drive.
# A extensão autentica com chrome.identity.launchWebAuthFlow; adicione o redirect
# https://<extension-id>.chromiumapp.org/ em "Authorized redirect URIs" do Client.
# O <extension-id> aparece em chrome://extensions com a extensão carregada.
# Sem esta variável, a opção "Conectar com Google" fica desabilitada.
VITE_GOOGLE_CLIENT_ID=
